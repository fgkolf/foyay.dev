---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Prose from "../components/Prose.astro";
import meImage from "../assets/me.jpg";
import Social from "../components/Social.astro";
---

<Layout>
  <div class="p-[4vw] bordered bg-(--bg-secondary-color)">
    <div class="flex flex-col sm:flex-row gap-6 items-start max-w-prose">
      <Image class="w-full sm:w-1/2 shrink-0" alt="That's me" src={meImage} />
      <Prose>
        <p>
          I'm a software engineer based in Athens. I build things for the web,
          and occasionally beyond it. Currently at Skroutz.
        </p>
        <p>
          This is where I share ideas, experiments, and things that catch my
          attention — alongside some of my work and whatever I'm currently
          excited about.
        </p>
        <p>
          Outside of code, I spend time making music playlists. You can find
          them <a href="https://open.spotify.com/user/fean0r11/playlists"
            >here</a
          >.
        </p>
        <div class="flex items-center gap-2">
          Let's get in touch: <Social />
        </div>
      </Prose>
    </div>
  </div>
</Layout>
